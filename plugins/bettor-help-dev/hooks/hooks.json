{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/onboarding-check.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "save_profile|build_lineups|mlb_generate_lineups",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/mark-onboarded.sh\""
          }
        ]
      }
    ]
  }
}
